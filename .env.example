# SDR Scanner Configuration
# Copy to .env and fill in your values

# Whisper transcription (OpenAI API)
# OPENAI_API_KEY=sk-...

# Expected languages for transcription (comma-separated, first = primary)
# WHISPER_LANGUAGES=es,ca,en,fr

# Self-hosted Whisper (uncomment to use instead of OpenAI)
# WHISPER_API_URL=http://myserver:8000/v1/audio/transcriptions

# Whisper backend: auto, api, or local
# WHISPER_BACKEND=auto

# TAK Server (used when config.pref is not in atak/)
# TAK_HOST=tak.example.com
# TAK_PORT=8089
